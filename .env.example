# Clubland client configuration template
#
# NOTE: the app reads these via --dart-define (String.fromEnvironment),
# NOT from a .env file. Pass them at build/run time, e.g.:
#   flutter run --dart-define=API_BASE_URL=http://192.168.x.x:30080
#   flutter build apk --release \
#     --dart-define=ENVIRONMENT=production \
#     --dart-define=API_BASE_URL=https://api.example.com \
#     --dart-define=HANKO_BASE_URL=https://auth.example.com
#
# Backend-only values (database, redis, fabric, JWT secrets) do NOT belong
# in the client — they live in the backend repo's configuration.

# Environment: development | staging | production
ENVIRONMENT=development

# API Configuration (required for staging/production builds; development
# defaults to http://localhost:8080)
API_BASE_URL=http://localhost:8080
# Optional override; defaults to $API_BASE_URL/graphql
GRAPHQL_ENDPOINT=

# Authentication (HANKO_BASE_URL required for staging/production builds)
HANKO_BASE_URL=http://localhost:8000
HANKO_API_KEY=your_hanko_api_key_here

# Monitoring & Analytics
SENTRY_DSN=your_sentry_dsn_here
AMPLITUDE_API_KEY=your_amplitude_key_here

# Feature Flags
ENABLE_LOGGING=true
ENABLE_ANALYTICS=false
ENABLE_CRASH_REPORTING=false

# API Timeouts (milliseconds)
CONNECT_TIMEOUT=10000
RECEIVE_TIMEOUT=30000
SEND_TIMEOUT=30000
